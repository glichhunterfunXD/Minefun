    // particle system
    class FxParticle {
        constructor(w, h, type, spd) {
            this.w = w; this.h = h;
            this.type = type;
            this.spd = spd;
            this.reset();
            if(this.type === 'bubbles' || this.type === 'fire') this.y = Math.random() * this.h;
        }
        reset() {
            this.x = Math.random() * this.w;
            this.y = (this.type === 'bubbles' || this.type === 'fire') ? this.h + Math.random() * 20 : Math.random() * this.h - this.h;
            this.size = Math.random() * 2 + 0.5;
            if(this.type === 'fire') this.size = Math.random() * 4 + 2;
            
            this.vy = (Math.random() * 1.5 + 0.5) * this.spd;
            if(this.type === 'rain') this.vy = (Math.random() * 5 + 5) * this.spd;
            if(this.type === 'matrix') this.vy = (Math.random() * 2 + 1.5) * this.spd;
            
            this.vx = (Math.random() - 0.5) * 0.5 * this.spd;
            this.alpha = Math.random() * 0.5 + 0.3;
            
            if(this.type === 'fire') this.color =['#ff0000', '#ff5a00', '#ff9a00'][Math.floor(Math.random()*3)];
            else if(this.type === 'matrix') this.color = '#0f0';
            else if(this.type === 'bubbles') this.color = 'rgba(255,255,255,0.5)';
            else if(this.type === 'rain') this.color = 'rgba(150, 200, 255, 0.6)';
            else this.color = `rgba(255, 255, 255, ${this.alpha})`;
        }
        tick() {
            if(this.type === 'bubbles' || this.type === 'fire') {
                this.y -= this.vy; this.x += this.vx;
                if(this.type === 'fire') {
                    this.size -= 0.05 * this.spd;
                    if(this.size <= 0.2) this.reset();
                }
                if(this.y < -10) this.reset();
            } else {
                this.y += this.vy; this.x += this.vx;
                if (this.y > this.h) this.reset();
            }
            if (this.x > this.w || this.x < 0) this.vx *= -1;
            
            if(this.type === 'stars') {
                this.alpha += (Math.random() - 0.5) * 0.1;
                if(this.alpha < 0.1) this.alpha = 0.1;
                if(this.alpha > 1) this.alpha = 1;
                this.color = `rgba(255, 255, 255, ${this.alpha})`;
            }
        }
        draw(c) {
            c.fillStyle = this.color; c.strokeStyle = this.color;
            if(this.type === 'rain') {
                c.beginPath(); c.moveTo(this.x, this.y); c.lineTo(this.x + this.vx, this.y + this.vy * 2); c.stroke();
            } else if(this.type === 'matrix') {
                c.font = `${Math.floor(this.size*5)}px monospace`; c.fillText(Math.floor(Math.random()*2), this.x, this.y);
            } else if (this.type === 'bubbles') {
                c.beginPath(); c.arc(this.x, this.y, this.size, 0, Math.PI * 2); c.stroke();
            } else {
                c.beginPath(); c.arc(this.x, this.y, this.size, 0, Math.PI * 2); c.fill();
            }
        }
    }

    const loadParticles = () => {
        particles =[];
        for(let i=0; i<config.particleCount; i++) {
            particles.push(new FxParticle(canvas.width, canvas.height, config.particleType, config.particleSpeed));
        }
    };

    const updateGameVisuals = () => {
        const gameCanvas = document.getElementById('canvas') || document.querySelector('canvas:not(#ks-canvas)');
        if (!gameCanvas) return;
        
        gameCanvas.style.transition = "transform 0.15s ease-out, filter 0.3s ease-out";
        gameCanvas.style.transformOrigin = "center center";
        
        // check if user is actually in a match so zoom doesn't trigger on menu
        const isPlaying = document.pointerLockElement !== null;
        let scaleStr = (isZooming && isPlaying) ? `scale(${config.zoomLevel})` : "scale(1)";
        let filterStr = config.nvEnabled ? `brightness(${config.nvIntensity}) contrast(0.92) saturate(1.1)` : "none";
        
        gameCanvas.style.transform = scaleStr;
        gameCanvas.style.filter = filterStr;
    };

    const applyUI = (box) => {
        keys.up.querySelector('.k-txt').innerText = config.upText;
        keys.left.querySelector('.k-txt').innerText = config.leftText;
        keys.down.querySelector('.k-txt').innerText = config.downText;
        keys.right.querySelector('.k-txt').innerText = config.rightText;
        keys.p.querySelector('.k-txt').innerText = config.pText;
        keys.c.querySelector('.k-txt').innerText = config.cText;
        keys.v.querySelector('.k-txt').innerText = config.vText;
        keys.shift.querySelector('.k-txt').innerText = config.rshiftText;
        keys.space.querySelector('.k-txt').innerText = config.spaceText;

        box.style.left = config.posX;
        box.style.top = config.posY;

        const root = document.documentElement.style;
        root.setProperty('--ks-font', config.fontFamily);
        root.setProperty('--ks-idle-rgb', hex2rgb(config.idleColor));
        root.setProperty('--ks-press', config.pressColor);
        root.setProperty('--ks-alpha', config.keyAlpha);
        root.setProperty('--ks-scale', config.scale);
        root.setProperty('--ks-radius', `${config.borderRadius}px`);
        root.setProperty('--ks-rgb-speed', `${config.rgbSpeed}s`);
        root.setProperty('--ks-glow-spread', `${config.glowSpread}px`);
        root.setProperty('--theme-grad', gradients[config.rgbTheme] || gradients['theme-1']);
        root.setProperty('--ks-img', config.bgUrl ? `url("${config.bgUrl}")` : 'none');

        box.classList.remove('bg-keys', 'bg-container');
        if(config.bgMode === 'keys') box.classList.add('bg-keys');
        else if(config.bgMode === 'container') box.classList.add('bg-container');

        box.classList.toggle('rgb-txt', config.rgbText);
        box.classList.toggle('rgb-bg', config.rgbBackground);
        box.classList.toggle('rgb-glow', config.rgbGlow);
        box.classList.toggle('txt-shadow', config.textShadow);
        document.getElementById('ks-info').style.display = config.showInfo ? 'block' : 'none';

        // prepopulate menu fields
        const getEl = (id) => document.getElementById(id);
        getEl('i-up').value = config.upKey; getEl('i-left').value = config.leftKey; getEl('i-down').value = config.downKey; getEl('i-right').value = config.rightKey;
        getEl('i-p').value = config.pKey; getEl('i-c').value = config.cKey; getEl('i-v').value = config.vKey; getEl('i-shift').value = config.rshiftKey;
        
        getEl('i-zoom').value = config.zoomLevel; getEl('i-nv').checked = config.nvEnabled; getEl('i-nvi').value = config.nvIntensity;
        getEl('i-bgurl').value = config.bgUrl; getEl('i-bgmode').value = config.bgMode;
        
        getEl('i-theme').value = config.rgbTheme; getEl('i-radius').value = config.borderRadius; getEl('i-idle').value = config.idleColor;
        getEl('i-press').value = config.pressColor; getEl('i-alpha').value = config.keyAlpha; getEl('i-rgbs').value = config.rgbSpeed;
        getEl('i-glows').value = config.glowSpread;

        getEl('i-rgbtxt').checked = config.rgbText; getEl('i-rgbbg').checked = config.rgbBackground; getEl('i-rgbglow').checked = config.rgbGlow;
        getEl('i-shadow').checked = config.textShadow; getEl('i-info').checked = config.showInfo;
        
        getEl('i-parton').checked = config.particles; getEl('i-ptype').value = config.particleType;
        getEl('i-pcnt').value = config.particleCount; getEl('i-pspd').value = config.particleSpeed;
        
        updateGameVisuals();
    };

    const setupInputs = (box, menu) => {
        const getBinds = () => ({
            [config.upKey.toLowerCase()]: 'up',[config.leftKey.toLowerCase()]: 'left', [config.downKey.toLowerCase()]: 'down',[config.rightKey.toLowerCase()]: 'right', [config.spaceKey.toLowerCase()]: 'space',[config.pKey.toLowerCase()]: 'p',
            [config.cKey.toLowerCase()]: 'c', [config.rshiftKey.toLowerCase()]: 'shift', [config.vKey.toLowerCase()]: 'v'
        });

        document.addEventListener('pointerlockchange', updateGameVisuals);

        window.addEventListener("keydown", e => {
            if (document.activeElement.tagName === "INPUT" && document.activeElement.type === "text") return;
            if (e.key === '\\') { menuOpen = !menuOpen; menu.classList.toggle('active', menuOpen); return; }

            const binds = getBinds();
            const hit = binds[e.key.toLowerCase()] || binds[e.code.toLowerCase()];
            if (hit) {
                keys[hit].classList.add("pressed");
                if (hit === 'v') { isZooming = true; updateGameVisuals(); }
            }
        });

        window.addEventListener("keyup", e => {
            const binds = getBinds();
            const hit = binds[e.key.toLowerCase()] || binds[e.code.toLowerCase()];
            if (hit) {
                keys[hit].classList.remove("pressed");
                if (hit === 'v') { isZooming = false; updateGameVisuals(); }
            }
        });

        window.addEventListener("mousedown", e => {
            if (e.button === 0) { lmbClicks.push(Date.now()); keys.lmb.classList.add("pressed"); } 
            else if (e.button === 2) { rmbClicks.push(Date.now()); keys.rmb.classList.add("pressed"); }
        });

        window.addEventListener("mouseup", e => {
            if (e.button === 0) keys.lmb.classList.remove("pressed");
            else if (e.button === 2) keys.rmb.classList.remove("pressed");
        });

        // live preview listeners
        const docStyles = document.documentElement.style;
        document.getElementById('i-theme').addEventListener('change', e => docStyles.setProperty('--theme-grad', gradients[e.target.value]));
        document.getElementById('i-radius').addEventListener('input', e => docStyles.setProperty('--ks-radius', `${e.target.value}px`));
        document.getElementById('i-alpha').addEventListener('input', e => docStyles.setProperty('--ks-alpha', e.target.value));
        document.getElementById('i-idle').addEventListener('input', e => docStyles.setProperty('--ks-idle-rgb', hex2rgb(e.target.value)));
        document.getElementById('i-press').addEventListener('input', e => docStyles.setProperty('--ks-press', e.target.value));
        document.getElementById('i-rgbs').addEventListener('input', e => docStyles.setProperty('--ks-rgb-speed', `${e.target.value}s`));
        document.getElementById('i-glows').addEventListener('input', e => docStyles.setProperty('--ks-glow-spread', `${e.target.value}px`));
        
        document.getElementById('i-parton').addEventListener('change', e => { config.particles = e.target.checked; });
        document.getElementById('i-ptype').addEventListener('change', e => { config.particleType = e.target.value; loadParticles(); });
        document.getElementById('i-pcnt').addEventListener('input', e => { config.particleCount = parseInt(e.target.value); loadParticles(); });
        document.getElementById('i-pspd').addEventListener('input', e => { config.particleSpeed = parseFloat(e.target.value); loadParticles(); });
        
        document.getElementById('i-zoom').addEventListener('input', e => { config.zoomLevel = parseFloat(e.target.value); if(isZooming) updateGameVisuals(); });
        document.getElementById('i-nv').addEventListener('change', e => { config.nvEnabled = e.target.checked; updateGameVisuals(); });
        document.getElementById('i-nvi').addEventListener('input', e => { config.nvIntensity = parseFloat(e.target.value); if(config.nvEnabled) updateGameVisuals(); });

        // save config logic
        document.getElementById('btn-save').addEventListener('click', () => {
            const getVal = (id) => document.getElementById(id).value;
            const getChk = (id) => document.getElementById(id).checked;

            config.upKey = getVal('i-up') || 'w'; config.leftKey = getVal('i-left') || 'a';
            config.downKey = getVal('i-down') || 's'; config.rightKey = getVal('i-right') || 'd';
            config.pKey = getVal('i-p') || 'p'; config.cKey = getVal('i-c') || 'c';
            config.vKey = getVal('i-v') || 'v'; config.rshiftKey = getVal('i-shift') || 'Shift';
            
            const txt = (k) => k.length === 1 ? k.toUpperCase() : k;
            config.upText = txt(config.upKey); config.leftText = txt(config.leftKey); config.downText = txt(config.downKey);
            config.rightText = txt(config.rightKey); config.pText = txt(config.pKey); config.cText = txt(config.cKey);
            config.vText = txt(config.vKey); config.rshiftText = "R-SH";
 
            config.zoomLevel = parseFloat(getVal('i-zoom'));
            config.nvEnabled = getChk('i-nv');
            config.nvIntensity = parseFloat(getVal('i-nvi'));

            config.bgUrl = getVal('i-bgurl').trim(); config.bgMode = getVal('i-bgmode');
 
            config.rgbTheme = getVal('i-theme'); config.borderRadius = parseInt(getVal('i-radius'));
            config.idleColor = getVal('i-idle'); config.pressColor = getVal('i-press');
            config.keyAlpha = parseFloat(getVal('i-alpha')); config.rgbSpeed = parseFloat(getVal('i-rgbs'));
            config.glowSpread = parseInt(getVal('i-glows'));
 
            config.rgbText = getChk('i-rgbtxt'); config.rgbBackground = getChk('i-rgbbg');
            config.rgbGlow = getChk('i-rgbglow'); config.textShadow = getChk('i-shadow'); config.showInfo = getChk('i-info');
 
            localStorage.setItem('keystrokes_config_v8', JSON.stringify(config));
            applyUI(box);
            
            menuOpen = false;
            menu.classList.remove('active');
        });
 
        const close = () => { menuOpen = false; menu.classList.remove('active'); applyUI(box); };
        document.getElementById('close-menu').addEventListener('click', close);
        menu.addEventListener('click', e => { if(e.target === menu) close(); });
    };

    const runRenderLoop = () => {
        frames++;
        const now = performance.now();
        if (now - lastTime >= 1000) {
            document.getElementById('v-fps').textContent = frames;
            frames = 0;
            lastTime = now;
        }

        if (ctx) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (config.particles) {
                for(let i=0; i<particles.length; i++) {
                    particles[i].tick();
                    particles[i].draw(ctx);
                }
            }
        }

        // prevent game from overwriting our filters when changing states
        if(frames % 60 === 0) updateGameVisuals();
 
        requestAnimationFrame(runRenderLoop);
    };

    const addDragging = (box) => {
        let dragging = false, sx, sy, il, it;
 
        const move = e => {
            if (!dragging) return;
            box.style.left = `${il + (e.clientX - sx)}px`;
            box.style.top = `${it + (e.clientY - sy)}px`;
        };
        const stop = () => {
            if (!dragging) return;
            dragging = false;
            box.classList.remove('dragging');
            config.posX = box.style.left; config.posY = box.style.top;
            localStorage.setItem('keystrokes_config_v8', JSON.stringify(config));
            document.removeEventListener('mousemove', move);
            document.removeEventListener('mouseup', stop);
        };
 
        box.addEventListener('mousedown', e => {
            if (e.button !== 0 || menuOpen) return;
            dragging = true;
            sx = e.clientX; sy = e.clientY;
            il = box.offsetLeft; it = box.offsetTop;
            box.classList.add('dragging');
            document.addEventListener('mousemove', move);
            document.addEventListener('mouseup', stop);
        });
    };

    // calculate click speed
    setInterval(() => {
        const now = Date.now();
        lmbClicks = lmbClicks.filter(t => now - t < 1000);
        rmbClicks = rmbClicks.filter(t => now - t < 1000);
        
        const lmbC = lmbClicks.length;
        keys.lmb.querySelector('.k-txt').textContent = `LMB: ${lmbC}`;
        keys.rmb.querySelector('.k-txt').textContent = `RMB: ${rmbClicks.length}`;
        
        if (lmbC > maxCps) {
            maxCps = lmbC;
            document.getElementById('v-peak').textContent = maxCps;
        }
    }, 50);

    const init = () => {
        const styleSheet = document.createElement("style");
        styleSheet.innerText = css;
        document.head.appendChild(styleSheet);
 
        const box = document.createElement("div");
        box.className = "keystrokes-box";
        box.innerHTML = overlayHtml;
        document.body.appendChild(box);
 
        const menu = document.createElement("div");
        menu.className = "menu-overlay";
        menu.innerHTML = menuHtml;
        document.body.appendChild(menu);
 
        const getK = (id) => document.getElementById(id);
        Object.assign(keys, {
            up: getK('btn-up'), left: getK('btn-left'), down: getK('btn-down'), right: getK('btn-right'),
            p: getK('btn-p'), c: getK('btn-c'), v: getK('btn-v'), shift: getK('btn-shift'),
            lmb: getK('btn-lmb'), rmb: getK('btn-rmb'), space: getK('btn-space')
        });
 
        canvas = document.getElementById('ks-canvas');
        ctx = canvas.getContext('2d');
        canvas.width = 316; canvas.height = 228;
        
        loadParticles();
        applyUI(box);
        setupInputs(box, menu);
        addDragging(box);
        
        requestAnimationFrame(runRenderLoop);
    };

    if (document.readyState === 'complete') init();
    else window.addEventListener('load', init);
})();
