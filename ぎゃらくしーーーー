function applyChat(){
    if(!data.mods.chat) return;
    const chat = document.querySelector(".chat");
    if(!chat) return;
    const positions = {
        "left":       { left:"0",  right:"auto", bottom:"0",  top:"auto",  transform:"none" },
        "right":      { left:"auto",right:"0",   bottom:"0",  top:"auto",  transform:"none" },
        "center":     { left:"50%",right:"auto", bottom:"0",  top:"auto",  transform:"translateX(-50%)" },
        "top_left":   { left:"0",  right:"auto", bottom:"auto",top:"0",   transform:"none" },
        "top_center": { left:"50%",right:"auto", bottom:"auto",top:"0",   transform:"translateX(-50%)" },
        "top_right":  { left:"auto",right:"0",   bottom:"auto",top:"0",   transform:"none" },
    };
    const pos = positions[data.chat.position] || positions["left"];
    chat.style.position  = "fixed";
    chat.style.left      = pos.left;
    chat.style.right     = pos.right;
    chat.style.bottom    = pos.bottom;
    chat.style.top       = pos.top;
    chat.style.transform = pos.transform;
    chat.style.zIndex    = "9999";
    const messages = document.querySelector(".messages");
    if(messages) messages.style.maxHeight = data.chat.longerChat ? "60vh" : "";
}
const chatWait = setInterval(() => { if(!document.querySelector(".chat")) return; clearInterval(chatWait); applyChat(); }, 500);
