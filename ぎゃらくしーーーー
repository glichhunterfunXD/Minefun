const overrides = {};
function overrideURL(url){ for(const orig in overrides){ if(url.includes(orig)) return overrides[orig]; } return url; }
function isGameActive(){ return !document.querySelector(".home"); }

const imgSrcDesc = Object.getOwnPropertyDescriptor(HTMLImageElement.prototype, "src");
Object.defineProperty(HTMLImageElement.prototype, "src", {
    set(value){ if(data.mods.textures && isGameActive()) value = overrideURL(value); return imgSrcDesc.set.call(this, value); },
    get(){ return imgSrcDesc.get.call(this); }
});

const origSetAttr = Element.prototype.setAttribute;
Element.prototype.setAttribute = function(name, value){
    if(data.mods.textures && name === "src" && isGameActive()) value = overrideURL(value);
    return origSetAttr.call(this, name, value);
};

function reloadAllImages(){ if(!data.mods.textures) return; document.querySelectorAll(".game img").forEach(img => { img.src = overrideURL(img.src); }); }
function updateTextureStatus(){ const s = document.getElementById("mf-texture-status"); if(!s) return; s.textContent = !data.mods.textures ? "Mod Disabled" : Object.keys(overrides).length ? "âœ“ Loaded" : "No pack loaded"; }
function resetAllTextureOverrides(){ for(const k in overrides) delete overrides[k]; if(data.textures) data.textures.overrides = {}; save(); updateTextureStatus(); document.querySelectorAll("img").forEach(img => { img.src = img.src; }); alert("Celestar: Texture pack removed"); }
function loadTexturePack(e){ const file = e.target.files[0]; if(!file) return; if(!data.mods.textures){ data.mods.textures = true; save(); } file.text().then(text => { const lines = text.split("\n"); const status = document.getElementById("mf-texture-status"); status.textContent = "Loadingâ€¦"; let loaded = false; for(const line of lines){ const idx = line.indexOf(">"); if(idx === -1) continue; const texture = line.slice(0, idx).trim(); const dataURL = line.slice(idx + 1).trim(); if(texture && dataURL){ overrides[texture] = dataURL; loaded = true; } } if(loaded){ updateTextureStatus(); saveTextureOverrides(); reloadAllImages(); } else { status.textContent = "Failed"; } }); }
function saveTextureOverrides(){ if(!data.textures || typeof data.textures !== "object") data.textures = {}; data.textures.overrides = {...overrides}; save(); }
const savedOverrides = data.textures?.overrides;
if(savedOverrides){ Object.assign(overrides, savedOverrides); reloadAllImages(); }

function buildTextureSettings(){
    settingsPage.insertAdjacentHTML("beforeend", `
        <div class="mf-settings-title">ðŸŽ¨ Texture Pack</div>
        <div class="mf-setting"><label>Upload Pack</label><input type="file" id="mf-texture-upload" accept=".txt"></div>
        <div class="mf-setting"><label>Status</label><span id="mf-texture-status">No pack loaded</span></div>
        <div class="mf-setting"><button id="mf-reset-textures">Reset Texture Pack</button></div>
    `);
    document.getElementById("mf-texture-upload").addEventListener("change", loadTexturePack);
    document.getElementById("mf-reset-textures").addEventListener("click", resetAllTextureOverrides);
    updateTextureStatus();
}

