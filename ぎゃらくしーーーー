}

function updateBetterChests(){
    if(!data.mods.betterChests) return;
    document.querySelectorAll(".chest").forEach(chest => {
        const items    = chest.querySelectorAll(".item");
        const count    = items.length;
        const tier     = getChestTier(count);
        const tierClass= `mf-chest-${tier}`;

        if(!chest.classList.contains("mf-space-chest")){
            chest.classList.add("mf-space-chest", tierClass);
            chest.style.position = "relative";
            addStarsToChest(chest, tier);
        }

        items.forEach(item => {
            if(!item.classList.contains("mf-chest-item")){
                item.classList.add("mf-chest-item");
            }
        });
    });
}
