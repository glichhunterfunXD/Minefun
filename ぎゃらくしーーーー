function getChestTier(itemCount){
    if(itemCount <= 9  || itemCount === 18) return "wood";
    if(itemCount <= 18 || itemCount === 27) return "iron";
    if(itemCount <= 36 || itemCount === 36) return "gold";
    return "diamond";
}

function addStarsToChest(chest, tier){
    if(chest.querySelector(".chest-star")) return;
    const colors = { wood:"#cd853f", iron:"#7ab0d0", gold:"#ffd700", diamond:"#00bfff" };
    const count  = { wood:2, iron:3, gold:5, diamond:8 }[tier];
    const color  = colors[tier];
    const w = chest.offsetWidth  || 120;
    const h = chest.offsetHeight || 80;
    for(let i = 0; i < count; i++){
        const star = document.createElement("span");
        star.className = "chest-star";
        star.textContent = ["âœ¦","â˜…","Â·","âœ§","*"][Math.floor(Math.random()*5)];
        star.style.cssText = `left:${Math.random()*90}%;top:${Math.random()*90}%;color:${color};animation-delay:${Math.random()*2}s;position:absolute;font-size:${6+Math.random()*6}px;pointer-events:none;`;
        chest.appendChild(star);
    }
    if(tier === "gold" || tier === "diamond"){
        const runes = ["â¬¡","â—ˆ","âŸ","â¬Ÿ","âŒ¬"];
        for(let i = 0; i < (tier === "diamond" ? 4 : 2); i++){
            const rune = document.createElement("span");
            rune.className = "chest-rune";
            rune.textContent = runes[Math.floor(Math.random()*runes.length)];
            rune.style.cssText = `left:${5+Math.random()*85}%;top:${5+Math.random()*85}%;position:absolute;font-size:10px;pointer-events:none;animation-delay:${Math.random()*3}s;`;
            chest.appendChild(rune);
        }
