document.addEventListener("mousemove", e => {
    if(!dragging) return;
    data.keystrokes.x = (e.clientX / innerWidth) * 100;
    data.keystrokes.y = ((innerHeight - e.clientY) / innerHeight) * 100;
    applyKeystrokes(); save();
});

